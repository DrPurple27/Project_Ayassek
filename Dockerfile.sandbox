FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    numpy \
    pandas \
    requests \
    httpx \
    pyyaml \
    python-dotenv

RUN useradd -m -u 1000 sandbox
USER sandbox
WORKDIR /home/sandbox
