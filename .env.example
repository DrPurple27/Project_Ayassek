# Ayassek Configuration

# Server
AYASSEK_HOST=0.0.0.0
AYASSEK_PORT=2727
AYASSEK_DEBUG=true

# Default Provider (openai, nim, ollama, vllm)
AYASSEK_DEFAULT_PROVIDER=ollama
AYASSEK_DEFAULT_MODEL=qwen3-vl:8b

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# NVIDIA NIM
NIM_API_KEY=your-nim-key-here
NIM_BASE_URL=https://ai.api.nvidia.com/v1

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# vLLM
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=

# Logging
AYASSEK_LOG_LEVEL=INFO
AYASSEK_LOG_FILE=data/logs/ayassek.log